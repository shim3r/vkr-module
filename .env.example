# --- Application Settings ---
# Directory where all JSON data and logs will be stored
SIEM_DATA_DIR=data
# Log level: DEBUG, INFO, WARNING, ERROR, CRITICAL
LOG_LEVEL=INFO

# --- Pipeline Settings ---
# How many days to keep raw logs before rotation
RAW_RETENTION_DAYS=14
# Max number of files in raw directory
RAW_MAX_FILES=5000
# Run cleanup routine every X events
RAW_CLEANUP_EVERY=50
# Size of the internal processing queue
PIPELINE_QUEUE_SIZE=1000
# Number of worker threads for processing pipeline
PIPELINE_WORKERS=2

# --- Security & Integration ---
# Webhook URL for incident notifications (Telegram/ServiceDesk)
WEBHOOK_URL=
# CORS Allowed Origins (Comma separated, e.g. http://localhost:3000,https://siem.example.com)
ALLOWED_ORIGINS=*

# --- Production Settings ---
# Set to 'production' to disable debug features (if applicable)
ENV_MODE=production
# Secret key for session management (if added in future)
SECRET_KEY=change-me-in-production-12345
